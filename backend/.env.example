# Copy to .env and adjust. See app/core/config.py for all options.

ENVIRONMENT=dev
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string
PUBLIC_BASE_URL=http://localhost:8080
FRONTEND_BASE_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Database / cache
DATABASE_URL=postgresql+asyncpg://aimirror:aimirror@localhost:5432/aimirror
REDIS_URL=redis://localhost:6379/0

# Object storage (MinIO)
S3_ENDPOINT_URL=http://localhost:9000
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# Payments (leave blank to use the built-in mock provider)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# OAuth (leave blank to disable a provider)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# Email (leave SMTP_HOST blank to log emails instead of sending)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=no-reply@aimirror.local
