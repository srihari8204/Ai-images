{
  "title": "AI Mirror — Platform Overview",
  "uid": "ai-mirror-overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate by status",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(rate(http_requests_total[5m])) by (status)", "legendFormat": "{{status}}" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "p95 latency (s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Error rate (%)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "100 * sum(rate(http_errors_total[5m])) / clamp_min(sum(rate(http_requests_total[5m])), 1)", "legendFormat": "error %" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Queue depth by priority",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "queue_depth", "legendFormat": "{{queue}}" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Stage duration p95 (s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(worker_stage_duration_seconds_bucket[5m])) by (le, stage))", "legendFormat": "{{stage}}" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "GPU utilization (%)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        { "expr": "worker_gpu_utilization_percent", "legendFormat": "gpu {{device}}" }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Jobs completed by status",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        { "expr": "sum(rate(worker_jobs_processed_total[5m])) by (status)", "legendFormat": "{{status}}" }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Revenue (cents/min) & credit txns",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        { "expr": "rate(revenue_cents_total[5m])", "legendFormat": "revenue" },
        { "expr": "sum(rate(credit_transactions_total[5m])) by (type)", "legendFormat": "{{type}}" }
      ]
    }
  ]
}
